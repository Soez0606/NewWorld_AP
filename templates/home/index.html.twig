{% extends 'base.html.twig' %}

{% block title %}Accueil - New World{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --nw-green: #2d5a27;
        --nw-light-green: #f1f8f1;
        --nw-accent: #e67e22; /* Orange pour le rappel de la terre/soleil */
    }

    .hero-section {
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                    url('https://images.unsplash.com/photo-1500937386664-56d1dfef3854?q=80&w=2070');
        background-size: cover;
        background-position: center;
        color: white;
        padding: 100px 0;
        border-radius: 0 0 50px 50px;
    }

    .btn-nw {
        background-color: var(--nw-accent);
        border: none;
        color: white;
        padding: 15px 30px;
        transition: transform 0.2s;
    }

    .btn-nw:hover {
        transform: scale(1.05);
        background-color: #d35400;
        color: white;
    }

    .step-card {
        border: none;
        border-top: 5px solid var(--nw-green);
        background-color: var(--nw-light-green);
        transition: all 0.3s;
    }

    .step-card:hover {
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .step-icon {
        font-size: 2rem;
        color: var(--nw-green);
        margin-bottom: 15px;
    }
</style>
{% endblock %}

{% block body %}
<div class="hero-section text-center mb-5">
    <div class="container">
        <h1 class="display-3 fw-bold mb-3">Bienvenue chez New World</h1>
        <p class="lead mb-4 fs-3">Cultivons ensemble le lien direct avec nos producteurs</p>
        <a href="{{ path('producer_registration') }}" class="btn btn-nw btn-lg rounded-pill shadow">
            <i class="fas fa-leaf me-2"></i>Devenir Producteur
        </a>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-md-8">
            <h2 class="mb-4" style="color: var(--nw-green);">Rejoignez l'aventure en 3 étapes</h2>
            <p class="text-muted">Nous accompagnons chaque producteur pour garantir la meilleure qualité à nos consommateurs.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 step-card p-4 text-center">
                <h4 class="fw-bold">1. Inscription</h4>
                <p class="text-muted">Présentez votre exploitation et vos produits via notre formulaire simplifié.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 step-card p-4 text-center">
                <h4 class="fw-bold">2. Validation</h4>
                <p class="text-muted">Notre équipe étudie votre dossier pour s'assurer de la cohérence avec nos valeurs.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 step-card p-4 text-center">
                <h4 class="fw-bold">3. Audit & Rencontre</h4>
                <p class="text-muted">Une visite sur place pour valider votre entrée officielle dans le réseau New World.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
