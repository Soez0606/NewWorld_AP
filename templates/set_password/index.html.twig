{# templates/set_password/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Définir votre mot de passe{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning">
                    <h3 class="mb-0">Définir votre mot de passe</h3>
                </div>
                <div class="card-body">
                    <p class="alert alert-info">
                        <strong>Première connexion !</strong><br>
                        Bienvenue {{ user.name }}. Veuillez définir votre mot de passe.
                    </p>
                    
                    {% for flash in app.flashes('error') %}
                        <div class="alert alert-danger">{{ flash }}</div>
                    {% endfor %}
                    
                    <form method="post">
                        <div class="mb-3">
                            <label for="password" class="form-label">Nouveau mot de passe</label>
                            <input type="password" id="password" name="password" class="form-control" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="confirm_password" class="form-label">Confirmer le mot de passe</label>
                            <input type="password" id="confirm_password" name="confirm_password" class="form-control" required>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Définir mon mot de passe</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}