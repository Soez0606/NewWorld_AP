{% extends 'base.html.twig' %}

{% block title %}Mon Profil Producteur{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">👤 Mon Profil</h3>
                    <a href="{{ path('producer_space_home') }}" class="btn btn-outline-light btn-sm">Retour</a>
                </div>
                <div class="card-body">
                    
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}

                    <div class="alert alert-info">
                        Certaines informations (Email, SIRET) ne sont pas modifiables directement. Contactez l'administration en cas de changement majeur.
                    </div>

                    {{ form_start(form) }}
                        <div class="row mb-3">
                            <div class="col-md-6">
                                {{ form_row(form.contact_name) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.phone) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.address) }}
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.activity) }}
                        </div>

                        <hr>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">💾 Enregistrer les modifications</button>
                        </div>
                    {{ form_end(form) }}
                    
                </div>
                <div class="card-footer text-muted text-center">
                    Compte lié à l'email : <strong>{{ app.user.email }}</strong> | SIRET : {{ producer.siret }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}