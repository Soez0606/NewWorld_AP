{% extends 'base.html.twig' %}

{% block title %}Accueil - New World{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-8">
            <h1 class="display-4 mb-4">Bienvenue chez New World</h1>
            <p class="lead mb-4">Rejoignez notre communauté de producteurs engagés</p>

            <div class="card mb-4">
                <div class="card-body">
                    <h3>Devenir Producteur</h3>
                    <p>Postulez pour rejoindre notre réseau de producteurs et bénéficier de nos services.</p>
                    <a href="{{ path('producer_registration') }}" class="btn btn-primary btn-lg">
                        Faire une demande d'inscription
                    </a>
                </div>
            </div>

            <div class="row mt-5">
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5>Inscription</h5>
                            <p>Remplissez votre dossier en ligne</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5>Validation</h5>
                            <p>Examen de votre dossier par notre équipe</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5>Audit</h5>
                            <p>Rencontre et validation finale</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
