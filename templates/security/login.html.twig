{% extends 'base.html.twig' %}

{% block title %}Connexion - New World{% endblock %}

{% block stylesheets %}
<style>
    .login-wrapper {
        background-color: #f8f5f2; /* Fond beige cohérent */
        min-height: 80vh;
        display: flex;
        align-items: center;
        padding: 40px 0;
    }

    .login-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border: none;
        overflow: hidden;
    }

    .login-header {
        background: var(--nw-dark-green); /* Vert profond du layout */
        color: white;
        padding: 35px;
        text-align: center;
    }

    .login-header h3 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .login-body {
        padding: 45px;
    }

    .form-label-custom {
        font-weight: 600;
        color: var(--nw-dark-green);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .form-control-custom {
        border: 2px solid #eee;
        border-radius: 10px;
        padding: 12px 15px;
        transition: all 0.3s ease;
    }

    .form-control-custom:focus {
        border-color: var(--nw-mid-green);
        box-shadow: none;
        background-color: #f1f8f1;
    }

    .btn-nw-primary {
        background-color: var(--nw-dark-green);
        color: white;
        border: none;
        padding: 15px;
        font-weight: 700;
        border-radius: 10px;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

    .btn-nw-primary:hover {
        background-color: var(--nw-mid-green);
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(27, 67, 50, 0.2);
        color: white;
    }

    .first-login-hint {
        background: #fff8e1;
        border-left: 4px solid #ffc107;
        padding: 10px 15px;
        border-radius: 4px;
        font-size: 0.85rem;
        color: #856404;
        margin-top: 8px;
    }
</style>
{% endblock %}

{% block body %}
<div class="login-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">

                <div class="card login-card">
                    <div class="login-header">
                        <h3>Bon retour parmi nous</h3>
                        <p class="mb-0 opacity-75 small">Accédez à votre espace producteur</p>
                    </div>

                    <div class="login-body">
                        <form method="post">
                            {% if error %}
                                <div class="alert alert-danger border-0 shadow-sm mb-4">
                                    {{ error.messageKey|trans(error.messageData, 'security') }}
                                </div>
                            {% endif %}

                            <div class="mb-4">
                                <label for="inputEmail" class="form-label-custom">Votre adresse Email</label>
                                <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                                       class="form-control-custom w-100" autocomplete="email"
                                       placeholder="nom@exemple.fr" required autofocus>
                            </div>

                            <div class="mb-4">
                                <label for="inputPassword" class="form-label-custom">Mot de passe</label>
                                <input type="password" name="password" id="inputPassword"
                                       class="form-control-custom w-100" autocomplete="current-password"
                                       placeholder="••••••••">

                                <div class="first-login-hint">
                                    <strong>Première connexion ?</strong> Laissez le champ vide pour configurer votre compte.
                                </div>
                            </div>

                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <button class="btn btn-nw-primary w-100 mt-3" type="submit">
                                Se connecter
                            </button>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <p class="text-muted small">Vous n'avez pas encore de compte ? <br>
                    <a href="{{ path('producer_registration') }}" class="text-success fw-bold text-decoration-none">Inscrivez-vous ici</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
