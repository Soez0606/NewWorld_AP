{% extends 'base.html.twig' %}

{% block title %}Mes Engagements - New World{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --nw-deep: #1b4332;
        --nw-clay: #b07d62;
        --nw-canvas: #faf9f6;
    }

    body { background-color: var(--nw-canvas); }

    .contracts-fluid {
        max-width: 1000px;
        margin: 0 auto;
        padding: 60px 20px;
    }

    .header-zone {
        margin-bottom: 50px;
    }

    .back-link {
        text-decoration: none;
        color: var(--nw-clay);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        display: inline-flex;
        align-items: center;
        transition: 0.3s;
    }

    .back-link:hover { transform: translateX(-5px); }

    /* Ligne de contrat style Monobloc */
    .contract-item {
        background: white;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 20px;
        border: 1px solid rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

    .contract-item:hover {
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transform: translateY(-3px);
    }

    .contract-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: #999;
        font-weight: 800;
        letter-spacing: 1px;
        margin-bottom: 5px;
        display: block;
    }

    .contract-data {
        font-weight: 600;
        color: var(--nw-deep);
        font-size: 1.05rem;
    }

    /* Badges personnalisés plus doux */
    .status-pill {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }
    .st-encours { background: #e8f5e9; color: #2d6a4f; }
    .st-demande { background: #fff3e0; color: #e67e22; }
    .st-attente { background: #e3f2fd; color: #1976d2; }
    .st-resilie { background: #ffebee; color: #c0392b; }

    .btn-action-outline {
        border: 2px solid #eee;
        color: #777;
        background: transparent;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        transition: all 0.3s;
    }

    .btn-action-outline:hover:not(:disabled) {
        border-color: #e74c3c;
        color: #e74c3c;
    }

    .new-request-zone {
        margin-top: 60px;
        padding: 40px;
        background: white;
        border-radius: 24px;
        border: 2px dashed #e0e0e0;
        text-align: center;
    }
</style>
{% endblock %}

{% block body %}
<div class="contracts-fluid">

    <div class="header-zone">
        <a href="{{ path('producer_space_home') }}" class="back-link">
             ← Retour au tableau de bord
        </a>
        <h1 class="display-5 fw-bold mt-3" style="font-family: 'Playfair Display', serif; color: var(--nw-deep);">
            Mes Engagements Juridiques
        </h1>
    </div>

    {% if contracts is empty %}
        <div class="text-center py-5">
            <p class="text-muted">Aucun contrat n'est actuellement rattaché à votre compte.</p>
        </div>
    {% else %}
        <div class="contracts-list">
            {% for contract in contracts %}
                <div class="contract-item">
                    <div class="row align-items-center">
                        <div class="col-md-2">
                            <span class="contract-label">Référence</span>
                            <span class="contract-data">#{{ contract.id }}</span>
                        </div>
                        <div class="mt-1 small text-muted fst-italic">
                             {{ contract.activityDescription ? contract.activityDescription : 'Activité principale' }}
                        </div>
                        <div class="col-md-2">
                            <span class="contract-label">Signé le</span>
                            <span class="contract-data">{{ contract.signatureDate|date('d/m/Y') }}</span>
                        </div>
                        <div class="col-md-3 text-center">
                            <span class="contract-label">Statut Actuel</span>
                            {% if contract.status == 'En cours' %}
                                <span class="status-pill st-encours">En cours</span>
                            {% elseif contract.status == 'Demande de résiliation' %}
                                <span class="status-pill st-demande">Résiliation envoyée</span>
                            {% elseif contract.status == 'En attente de validation' %}
                                <span class="status-pill st-attente">En attente</span>
                            {% elseif contract.status == 'Résilié' %}
                                <span class="status-pill st-resilie">Résilié</span>
                            {% else %}
                                <span class="status-pill bg-light text-muted">{{ contract.status }}</span>
                            {% endif %}
                        </div>
                        <div class="col-md-2">
                            <span class="contract-label">Fin prévue</span>
                            <span class="contract-data">
                                {{ contract.expirationDate ? contract.expirationDate|date('d/m/Y') : 'Indéterminée' }}
                            </span>
                        </div>
                        <div class="col-md-3 text-end">
                            {% if contract.status == 'En cours' %}
                                <a href="{{ path('producer_request_termination', {id: contract.id}) }}"
                                   class="btn-action-outline text-decoration-none"
                                   onclick="return confirm('Confirmer la demande de résiliation ? (Préavis de {{ contract.noticeMonths }} mois)')">
                                    Résilier
                                </a>
                            {% else %}
                                <button class="btn-action-outline" disabled>Action restreinte</button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

   <hr class="mt-5" style="opacity: 0.1;">
        
    <div class="new-request-zone mt-4">
        <h4 class="fw-bold text-center mb-4" style="color: var(--nw-deep);">Étendre notre partenariat</h4>
        
        <div class="row g-4">
            <div class="col-md-6">
                <div class="p-4 bg-white border rounded-3 text-center h-100 shadow-sm">
                    <div class="mb-3" style="font-size: 2rem;">🔄</div>
                    <h5 class="fw-bold" style="color: var(--nw-deep);">Poursuivre mon activité</h5>
                    <p class="text-muted small mb-4">Demander un nouveau contrat pour votre production habituelle (celle renseignée lors de votre inscription).</p>
                    
                    <form action="{{ path('producer_request_new_contract') }}" method="POST">
                        <button type="submit" class="shadow-sm border-0 w-100"
                           style="background-color: var(--nw-clay); color: white; padding: 12px 20px; border-radius: 50px; font-weight: 600; transition: 0.3s;"
                           onmouseover="this.style.backgroundColor='#8e634d'"
                           onmouseout="this.style.backgroundColor='var(--nw-clay)'"
                           onclick="return confirm('Demander un nouveau contrat pour votre activité principale ?')">
                            Demander un contrat classique
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-md-6">
                <div class="p-4 bg-white border rounded-3 text-center h-100 shadow-sm">
                    <div class="mb-3" style="font-size: 2rem;">➕</div>
                    <h5 class="fw-bold" style="color: var(--nw-deep);">Proposer une nouveauté</h5>
                    <p class="text-muted small mb-3">Vous avez diversifié votre exploitation et souhaitez nous proposer de nouveaux produits ?</p>
                    
                    <form action="{{ path('producer_request_new_contract') }}" method="POST">
                        <textarea name="new_activity" class="form-control mb-3" rows="2" placeholder="Ex: Création d'un élevage de poules, Miel..." required></textarea>
                        <button type="submit" class="shadow-sm border-0 w-100"
                           style="background-color: var(--nw-deep); color: white; padding: 12px 20px; border-radius: 50px; font-weight: 600; transition: 0.3s;"
                           onmouseover="this.style.backgroundColor='var(--nw-mid-green)'"
                           onmouseout="this.style.backgroundColor='var(--nw-deep)'"
                           onclick="return confirm('Soumettre cette nouvelle activité à la direction ?')">
                            Envoyer la nouvelle proposition
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}