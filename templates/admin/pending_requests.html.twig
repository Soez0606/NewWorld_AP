{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}📋 Demandes en attente de validation{% endblock %}

{% block page_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Demandes en attente ({{ producers|length }})</h1>
    <a href="{{ path('admin') }}" class="btn btn-secondary">← Retour au dashboard</a>
</div>

{% if app.session.get('pending_mailto') %}
    <div class="alert alert-info alert-dismissible fade show">
        <h5>📧 Email prêt à être envoyé</h5>
        <p>Cliquez sur le bouton ci-dessous pour ouvrir votre client email :</p>
        <a href="{{ app.session.get('pending_mailto') }}" class="btn btn-success btn-lg">📨 Ouvrir l'email</a>
        <a href="{{ path('admin_pending_requests') }}" class="btn btn-secondary">Fermer</a>
    </div>
{% endif %}

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for message in app.flashes('warning') %}
    <div class="alert alert-warning alert-dismissible fade show">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% if producers|length == 0 %}
<div class="alert alert-success">
    <h4>✅ Aucune demande en attente</h4>
    <p>Toutes les demandes ont été traitées.</p>
</div>
{% else %}
<div class="row">
    {% for producer in producers %}
    <div class="col-md-6 mb-4">
        <div class="card h-100 border-warning">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Demande #{{ producer.id }}</h5>
                <span class="badge bg-dark">En attente</span>
            </div>
            <div class="card-body">
                <p><strong>👤 Contact:</strong> {{ producer.contactName }}</p>
                <p><strong>📧 Email:</strong> {{ producer.email }}</p>
                <p><strong>📅 Date:</strong> {{ producer.registrationDate|date('d/m/Y H:i') }}</p>
                <p><strong>🏢 SIRET:</strong> {{ producer.siret }}</p>
                <p><strong>📞 Téléphone:</strong> {{ producer.phone }}</p>
                <p><strong>📍 Adresse:</strong> {{ producer.address }}</p>
                <p><strong>💼 Activité:</strong><br>{{ producer.activity|slice(0, 150) }}...</p>
            </div>
            <div class="card-footer">
                <div class="btn-group w-100">
                    <a href="{{ path('admin_producer_validate', {id: producer.id}) }}" 
                       class="btn btn-success" 
                       onclick="return confirm('Valider cette demande ? Un email d\\'audit sera envoyé à {{ producer.email }}.')">
                        ✅ Valider
                    </a>
                    <a href="{{ path('admin_producer_reject', {id: producer.id}) }}" 
                       class="btn btn-danger"
                       onclick="return confirm('Refuser cette demande ? Un email de refus sera envoyé à {{ producer.email }}.')">
                        ❌ Refuser
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}